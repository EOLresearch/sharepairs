# Copy to .env or set in Lambda environment
STAGE=dev
AWS_REGION=us-east-1

# DynamoDB table names (default: sharepairs-{STAGE}-users, etc.)
USERS_TABLE=sharepairs-dev-users
CONVERSATIONS_TABLE=sharepairs-dev-conversations
MESSAGES_TABLE=sharepairs-dev-messages

# Stub auth for local/dev (set to true to use email/password from users table)
STUB_AUTH=true
STUB_AUTH_SECRET=your-random-secret-change-in-prod

# CORS (use your frontend origin in prod)
CORS_ORIGIN=*

# Optional: DynamoDB Local
# DYNAMODB_ENDPOINT=http://localhost:8000

# Optional: Lambda local
# IS_LOCAL=true
# AWS_SAM_LOCAL=true
